APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qr_api
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# API Key para proteger los endpoints de este microservicio
API_KEY=

# BNB - Banco Nacional de Bolivia
# Credenciales otorgadas por el banco (ambiente de pruebas)
BNB_ACCOUNT_ID=
BNB_AUTHORIZATION_ID=
BNB_AUTH_URL=http://test.bnb.com.bo/ClientAuthentication.API/api/v1/auth
BNB_QR_URL=http://test.bnb.com.bo/QRSimple.API/api/v1/main
# BNB_TOKEN_TTL=3000

# Union - Banco Unión (UNIQR Service — SOAP/XML)
# Credenciales otorgadas por el banco
UNION_USUARIO=
UNION_CONTRASENA=
UNION_NRO_COMERCIO=
UNION_NRO_SUCURSAL=1
UNION_NRO_AGENCIA=1
UNION_NRO_POS=1
# Clave para encriptar el password con AES-256-ECB (en pruebas es "12345678")
UNION_AES_KEY=12345678
# Rutas absolutas a los archivos del certificado X509 (entregados por el banco)
UNION_CERT_PATH=/ruta/al/certificado.pem
UNION_KEY_PATH=/ruta/a/la/clave_privada.pem
# URL del servicio SOAP
UNION_WSDL_URL=https://test-unbunqr.bancounion.com.bo/WS_QR/BunQR.svc?wsdl
# Token Bearer que Banco Unión usa para llamar al endpoint de conciliación
UNION_CONCILIATION_TOKEN=
